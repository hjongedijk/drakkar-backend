NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/usenet_vfs
REDIS_URL=redis://redis:6379
APP_BASE_URL=http://localhost:3000

CONFIG_DIR=/config
VFS_ROOT=/vfs
VFS_DOWNLOADS_DIR=/vfs/downloads
VFS_COMPLETED_DIR=/vfs/completed
VFS_NZB_DIR=/vfs/nzb
VFS_IDS_DIR=/vfs/.ids
VFS_METADATA_DIR=/vfs/.metadata
VFS_TMP_DIR=/vfs/.tmp
VFS_FAILED_DIR=/vfs/.failed
MEDIA_SYMLINKS_DIR=/mnt/usenet-vfs
MEDIA_MOVIES_DIR=/mnt/usenet-vfs/movies
MEDIA_TV_DIR=/mnt/usenet-vfs/tv
NZB_BACKUPS_DIR=/mnt/usenet-vfs/nzb-backup
LOGS_DIR=/logs
FUSE_MOUNT_ENABLED=false
FUSE_MOUNT_PATH=/fuse/vfs
FUSE_ALLOW_OTHER=false
FUSE_FORCE_MOUNT=true
FUSE_DEBUG=false
TEST_CONNECTION_DATA_PATH=/config/test-connection-data.json
AUTO_IMPORT_TEST_CONNECTION_DATA=false

generator client {
  provider = "prisma-client"
  output   = "../src/models/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  displayName  String?
  passwordHash String?
  isAdmin      Boolean    @default(false)
  mustChangePassword Boolean @default(false)
  apiKeys      ApiKey[]
  auditLogs    AuditLog[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model ApiKey {
  id        String   @id @default(cuid())
  name      String
  keyHash   String   @unique
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  lastUsedAt DateTime?
  createdAt DateTime @default(now())
  revokedAt DateTime?
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action    String
  entity    String?
  entityId  String?
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())
}

model QualityProfile {
  id                 String            @id @default(cuid())
  name               String            @unique
  allowedQualities   String[]
  cutoffQuality      String?
  preferredWords     String[]
  rejectedWords      String[]
  requiredWords      String[]
  minSize            Float?
  maxSize            Float?
  preferredLanguages String[]
  requiredLanguages  String[]
  allowHDR           Boolean           @default(true)
  allowDV            Boolean           @default(true)
  allowRemux         Boolean           @default(true)
  allowBluRay        Boolean           @default(true)
  allowWebDL         Boolean           @default(true)
  allowWebRip        Boolean           @default(true)
  allowX264          Boolean           @default(true)
  allowX265          Boolean           @default(true)
  allowAV1           Boolean           @default(true)
  allowMultiAudio    Boolean           @default(true)
  rejectCam          Boolean           @default(true)
  rejectTelesync     Boolean           @default(true)
  rejectScreener     Boolean           @default(true)
  rejectPassworded   Boolean           @default(true)
  rejectSuspicious   Boolean           @default(true)
  preferProper       Boolean           @default(true)
  preferRepack       Boolean           @default(true)
  rules              QualityRule[]
  decisions          ReleaseDecision[]
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
}

model QualityRule {
  id        String         @id @default(cuid())
  profileId String
  profile   QualityProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  kind      String
  value     String
  score     Int            @default(0)
  required  Boolean        @default(false)
  rejected  Boolean        @default(false)
  createdAt DateTime       @default(now())
}

model ReleaseDecision {
  id           String          @id @default(cuid())
  profileId    String?
  profile      QualityProfile? @relation(fields: [profileId], references: [id], onDelete: SetNull)
  releaseTitle String
  releaseGuid  String?
  accepted     Boolean
  score        Int
  reasons      String[]
  parsed       Json
  createdAt    DateTime        @default(now())

  @@index([createdAt])
}

model SearchHistory {
  id        String   @id @default(cuid())
  type      String
  query     Json
  resultCount Int
  status    String
  message   String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model UsenetServer {
  id            String   @id @default(cuid())
  name          String
  host          String
  port          Int
  ssl           Boolean  @default(true)
  username      String?
  password      String?
  connections   Int      @default(10)
  priority      Int      @default(0)
  enabled       Boolean  @default(true)
  isBackup      Boolean  @default(false)
  retentionDays Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([enabled, isBackup, priority])
}

model NzbDocument {
  id          String    @id @default(cuid())
  title       String
  guid        String?   @unique
  path        String
  backupPath  String?
  poster      String?
  groups      String[]
  totalSize   Float     @default(0)
  fileCount   Int       @default(0)
  segmentCount Int      @default(0)
  valid       Boolean   @default(true)
  errors      String[]
  files       NzbFile[]
  mounts      VfsMount[]
  archiveEntries ArchiveEntry[]
  download    Download?
  mediaFiles  MediaFile[]
  createdAt   DateTime  @default(now())
}

model NzbFile {
  id            String       @id @default(cuid())
  nzbDocumentId String
  nzbDocument   NzbDocument  @relation(fields: [nzbDocumentId], references: [id], onDelete: Cascade)
  subject       String
  poster        String?
  date          DateTime?
  groups        String[]
  size          Float        @default(0)
  segments      NzbSegment[]

  @@index([nzbDocumentId])
}

model NzbSegment {
  id        String  @id @default(cuid())
  nzbFileId String
  nzbFile   NzbFile @relation(fields: [nzbFileId], references: [id], onDelete: Cascade)
  number    Int
  bytes     Float
  articleId String

  @@index([nzbFileId, number])
}

model VfsMount {
  id            String      @id @default(cuid())
  nzbDocumentId String
  nzbDocument   NzbDocument @relation(fields: [nzbDocumentId], references: [id], onDelete: Cascade)
  name          String
  path          String      @unique
  status        String      @default("mounted")
  streamable    Boolean     @default(false)
  mediaFiles    MediaFile[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([createdAt])
}

model ArchiveEntry {
  id            String           @id @default(cuid())
  nzbDocumentId String
  nzbDocument   NzbDocument      @relation(fields: [nzbDocumentId], references: [id], onDelete: Cascade)
  name          String
  path          String
  format        String
  compression   String
  size          Float
  modifiedAt    DateTime
  status        String           @default("streamable")
  segments      ArchiveSegment[]
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  @@unique([nzbDocumentId, path])
  @@index([nzbDocumentId])
}

model ArchiveSegment {
  id             String       @id @default(cuid())
  archiveEntryId String
  archiveEntry   ArchiveEntry @relation(fields: [archiveEntryId], references: [id], onDelete: Cascade)
  nzbFileId      String
  articleId      String
  segmentNumber  Int
  bytes          Float
  start          Float
  end            Float
  sourceOffset   Float

  @@index([archiveEntryId, start])
}

model Download {
  id            String       @id @default(cuid())
  title         String
  source        String
  status        String       @default("queued")
  priority      Int          @default(0)
  progress      Float        @default(0)
  size          Float        @default(0)
  downloaded    Float        @default(0)
  speedBytesSec Float        @default(0)
  etaSeconds    Int?
  error         String?
  nzbDocumentId String?      @unique
  nzbDocument   NzbDocument? @relation(fields: [nzbDocumentId], references: [id], onDelete: SetNull)
  jobId         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  completedAt   DateTime?
  repairJobs     RepairJob[]
  imports        ImportItem[]
  mediaFiles     MediaFile[]

  @@index([status, updatedAt])
  @@index([createdAt])
}

model Movie {
  id             String             @id @default(cuid())
  tmdbId         String             @unique @map("tmdb_id")
  imdbId         String?            @map("imdb_id")
  tvdbId         String?            @map("tvdb_id")
  title          String
  originalTitle  String?            @map("original_title")
  overview       String?
  releaseDate    DateTime?          @map("release_date")
  year           Int?
  runtimeMinutes Int?               @map("runtime_minutes")
  posterPath     String?            @map("poster_path")
  backdropPath   String?            @map("backdrop_path")
  rawSeerr       Json?              @map("raw_seerr")
  rawTmdb        Json?              @map("raw_tmdb")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")
  requests       MediaRequest[]     @relation("MovieRequests")
  libraryItems   MediaLibraryItem[] @relation("MovieLibraryItems")
  mediaFiles     MediaFile[]        @relation("MovieFiles")

  @@index([title])
  @@index([year])
  @@index([imdbId])
  @@index([tvdbId])
  @@map("movies")
}

model TvShow {
  id               String             @id @default(cuid())
  tmdbId           String             @unique @map("tmdb_id")
  imdbId           String?            @map("imdb_id")
  tvdbId           String?            @map("tvdb_id")
  title            String
  originalTitle    String?            @map("original_title")
  overview         String?
  firstAirDate     DateTime?          @map("first_air_date")
  lastAirDate      DateTime?          @map("last_air_date")
  year             Int?
  posterPath       String?            @map("poster_path")
  backdropPath     String?            @map("backdrop_path")
  numberOfSeasons  Int?               @map("number_of_seasons")
  numberOfEpisodes Int?               @map("number_of_episodes")
  rawSeerr         Json?              @map("raw_seerr")
  rawTmdb          Json?              @map("raw_tmdb")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  seasons          TvSeason[]
  episodes         TvEpisode[]
  requests         MediaRequest[]     @relation("TvShowRequests")
  libraryItems     MediaLibraryItem[] @relation("TvShowLibraryItems")

  @@index([title])
  @@index([year])
  @@index([imdbId])
  @@index([tvdbId])
  @@map("tv_shows")
}

model TvSeason {
  id           String             @id @default(cuid())
  tvShowId     String             @map("tv_show_id")
  tvShow       TvShow             @relation(fields: [tvShowId], references: [id], onDelete: Cascade)
  tmdbId       String?            @map("tmdb_id")
  tvdbId       String?            @map("tvdb_id")
  seasonNumber Int                @map("season_number")
  title        String?
  overview     String?
  airDate      DateTime?          @map("air_date")
  posterPath   String?            @map("poster_path")
  episodeCount Int?               @map("episode_count")
  rawSeerr     Json?              @map("raw_seerr")
  rawTmdb      Json?              @map("raw_tmdb")
  createdAt    DateTime           @default(now()) @map("created_at")
  updatedAt    DateTime           @updatedAt @map("updated_at")
  episodes     TvEpisode[]
  requests     MediaRequest[]     @relation("TvSeasonRequests")
  libraryItems MediaLibraryItem[] @relation("TvSeasonLibraryItems")

  @@unique([tvShowId, seasonNumber])
  @@index([tvShowId])
  @@index([tvShowId, seasonNumber])
  @@index([tmdbId])
  @@index([tvdbId])
  @@map("tv_seasons")
}

model TvEpisode {
  id                    String             @id @default(cuid())
  tvShowId              String             @map("tv_show_id")
  tvShow                TvShow             @relation(fields: [tvShowId], references: [id], onDelete: Cascade)
  seasonId              String             @map("season_id")
  season                TvSeason           @relation(fields: [seasonId], references: [id], onDelete: Cascade)
  tmdbId                String?            @map("tmdb_id")
  imdbId                String?            @map("imdb_id")
  tvdbId                String?            @map("tvdb_id")
  seasonNumber          Int                @map("season_number")
  episodeNumber         Int                @map("episode_number")
  absoluteEpisodeNumber Int?               @map("absolute_episode_number")
  title                 String
  overview              String?
  airDate               DateTime?          @map("air_date")
  runtimeMinutes        Int?               @map("runtime_minutes")
  stillPath             String?            @map("still_path")
  rawSeerr              Json?              @map("raw_seerr")
  rawTmdb               Json?              @map("raw_tmdb")
  createdAt             DateTime           @default(now()) @map("created_at")
  updatedAt             DateTime           @updatedAt @map("updated_at")
  requests              MediaRequest[]     @relation("TvEpisodeRequests")
  libraryItems          MediaLibraryItem[] @relation("TvEpisodeLibraryItems")
  mediaFiles            MediaFile[]        @relation("TvEpisodeFiles")

  @@unique([tvShowId, seasonNumber, episodeNumber])
  @@unique([seasonId, episodeNumber])
  @@index([tvShowId])
  @@index([seasonId])
  @@index([tvShowId, seasonNumber, episodeNumber])
  @@index([tmdbId])
  @@index([imdbId])
  @@index([tvdbId])
  @@map("tv_episodes")
}

model RequestProvider {
  id                  String         @id @default(cuid())
  type                String
  name                String
  baseUrl             String
  apiKey              String
  enabled             Boolean        @default(true)
  syncIntervalMinutes Int            @default(15)
  defaultMovieProfile String?
  defaultTvProfile    String?
  lastSyncAt          DateTime?
  lastError           String?
  requests            MediaRequest[]
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  @@index([enabled, name])
}

model MediaRequest {
  id                String           @id @default(cuid())
  providerId        String?
  provider          RequestProvider? @relation(fields: [providerId], references: [id], onDelete: SetNull)
  externalId        String
  mediaType         String
  title             String
  year              Int?
  tmdbId            String?
  tvdbId            String?
  imdbId            String?
  seasons           Json?
  episodes          Json?
  requestedBy       String?
  requestedQuality  String?
  externalStatus    String?
  status            String           @default("pending")
  selectedProfileId String?
  selectedRelease   Json?
  movieId           String?
  movie             Movie?           @relation("MovieRequests", fields: [movieId], references: [id], onDelete: SetNull)
  tvShowId          String?
  tvShow            TvShow?          @relation("TvShowRequests", fields: [tvShowId], references: [id], onDelete: SetNull)
  seasonId          String?
  seasonTarget      TvSeason?        @relation("TvSeasonRequests", fields: [seasonId], references: [id], onDelete: SetNull)
  episodeId         String?
  episodeTarget     TvEpisode?       @relation("TvEpisodeRequests", fields: [episodeId], references: [id], onDelete: SetNull)
  rawRequest        Json?
  rawMedia          Json?
  downloadId        String?
  imports           ImportItem[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@unique([providerId, externalId])
  @@index([downloadId])
  @@index([status, createdAt])
  @@index([movieId])
  @@index([tvShowId])
  @@index([seasonId])
  @@index([episodeId])
  @@map("media_requests")
}

model RepairJob {
  id          String   @id @default(cuid())
  downloadId  String
  download    Download @relation(fields: [downloadId], references: [id], onDelete: Cascade)
  type        String
  status      String   @default("queued")
  message     String?
  output      String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([downloadId, createdAt])
}

model FailedRelease {
  id         String   @id @default(cuid())
  guid       String?
  title      String
  reason    String
  downloadId String?
  createdAt DateTime @default(now())

  @@index([createdAt])
}

model BlocklistItem {
  id          String   @id @default(cuid())
  guid        String?
  title       String
  reason      String
  source      String?
  release     Json?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([createdAt])
  @@index([guid])
}

model ImportItem {
  id            String       @id @default(cuid())
  identityKey   String       @unique
  downloadId    String?
  download      Download?    @relation(fields: [downloadId], references: [id], onDelete: SetNull)
  requestId     String?
  request       MediaRequest? @relation(fields: [requestId], references: [id], onDelete: SetNull)
  mediaType     String
  title         String
  year          Int?
  season        Int?
  episode       Int?
  sourcePath    String
  completedPath String
  status        String       @default("imported")
  metadataPath  String?
  stableIdPath  String?
  mediaFiles    MediaFile[]
  symlinks      Symlink[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([downloadId])
  @@index([requestId])
  @@index([mediaType, title, year, season, episode])
  @@index([createdAt])
  @@map("media_import_items")
}

model Symlink {
  id          String     @id @default(cuid())
  importId    String?
  importItem  ImportItem? @relation(fields: [importId], references: [id], onDelete: SetNull)
  sourcePath  String
  linkPath    String     @unique
  status      String     @default("ok")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([importId])
  @@index([status, updatedAt])
  @@map("media_symlinks")
}

model MediaLibraryItem {
  id                String   @id @default(cuid())
  sourceKey         String   @unique
  identityKey       String   @unique
  mediaType         String
  movieId           String?
  movie             Movie?   @relation("MovieLibraryItems", fields: [movieId], references: [id], onDelete: SetNull)
  tvShowId          String?
  tvShow            TvShow?  @relation("TvShowLibraryItems", fields: [tvShowId], references: [id], onDelete: SetNull)
  seasonId          String?
  seasonTarget      TvSeason? @relation("TvSeasonLibraryItems", fields: [seasonId], references: [id], onDelete: SetNull)
  episodeId         String?
  episodeTarget     TvEpisode? @relation("TvEpisodeLibraryItems", fields: [episodeId], references: [id], onDelete: SetNull)
  title             String
  sortTitle         String
  year              Int?
  tmdbId            String?
  tvdbId            String?
  imdbId            String?
  season            Int?
  episode           Int?
  requestedBy       String?
  requestProvider   String?
  requestId         String?
  qualityProfileId  String?
  selectedReleaseId String?
  downloadId        String?
  nzbId             String?
  vfsMountId        String?
  importStrategy    String?
  libraryStatus     String   @default("requested")
  streamStatus      String   @default("unknown")
  healthStatus      String   @default("unknown")
  folderPath        String?
  filePath          String?
  symlinkPath       String?
  strmPath          String?
  quality           String?
  source            String?
  codec             String?
  audio             String?
  hdr               Boolean  @default(false)
  dv                Boolean  @default(false)
  releaseGroup      String?
  size              Float?
  duration          Float?
  lastStreamedAt    DateTime?
  streamCount       Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([libraryStatus, sortTitle, createdAt])
  @@index([requestId])
  @@index([downloadId])
  @@index([filePath])
  @@index([lastStreamedAt])
  @@index([movieId])
  @@index([tvShowId])
  @@index([seasonId])
  @@index([episodeId])
  @@map("media_library_items")
}

model MediaFile {
  id           String      @id @default(cuid())
  mediaType    String      @map("media_type")
  movieId      String?     @map("movie_id")
  movie        Movie?      @relation("MovieFiles", fields: [movieId], references: [id], onDelete: Cascade)
  episodeId    String?     @map("episode_id")
  episode      TvEpisode?  @relation("TvEpisodeFiles", fields: [episodeId], references: [id], onDelete: Cascade)
  importId     String?     @map("import_id")
  importItem   ImportItem? @relation(fields: [importId], references: [id], onDelete: SetNull)
  downloadId   String?     @map("download_id")
  download     Download?   @relation(fields: [downloadId], references: [id], onDelete: SetNull)
  nzbId        String?     @map("nzb_id")
  nzbDocument  NzbDocument? @relation(fields: [nzbId], references: [id], onDelete: SetNull)
  vfsMountId   String?     @map("vfs_mount_id")
  vfsMount     VfsMount?   @relation(fields: [vfsMountId], references: [id], onDelete: SetNull)
  path         String?     @unique
  folderPath   String?     @map("folder_path")
  filePath     String?     @unique @map("file_path")
  symlinkPath  String?     @unique @map("symlink_path")
  strmPath     String?     @unique @map("strm_path")
  filename     String?
  size         Float?
  duration     Float?
  quality      String?
  source       String?
  codec        String?
  audio        String?
  hdr          Boolean     @default(false)
  dv           Boolean     @default(false)
  releaseGroup String?     @map("release_group")
  isAvailable  Boolean     @default(true) @map("is_available")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  @@index([movieId])
  @@index([episodeId])
  @@index([importId])
  @@index([downloadId])
  @@index([nzbId])
  @@index([vfsMountId])
  @@index([isAvailable])
  @@map("media_files")
}

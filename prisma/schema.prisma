generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  displayName  String?
  passwordHash String?
  isAdmin      Boolean    @default(false)
  apiKeys      ApiKey[]
  auditLogs    AuditLog[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model ApiKey {
  id        String   @id @default(cuid())
  name      String
  keyHash   String   @unique
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  lastUsedAt DateTime?
  createdAt DateTime @default(now())
  revokedAt DateTime?
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AuditLog {
  id        String   @id @default(cuid())
  actorId   String?
  actor     User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  action    String
  entity    String?
  entityId  String?
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())
}

model QualityProfile {
  id                 String            @id @default(cuid())
  name               String            @unique
  allowedQualities   String[]
  cutoffQuality      String?
  preferredWords     String[]
  rejectedWords      String[]
  requiredWords      String[]
  minSize            Float?
  maxSize            Float?
  preferredLanguages String[]
  requiredLanguages  String[]
  allowHDR           Boolean           @default(true)
  allowDV            Boolean           @default(true)
  allowRemux         Boolean           @default(true)
  allowBluRay        Boolean           @default(true)
  allowWebDL         Boolean           @default(true)
  allowWebRip        Boolean           @default(true)
  allowX264          Boolean           @default(true)
  allowX265          Boolean           @default(true)
  allowAV1           Boolean           @default(true)
  allowMultiAudio    Boolean           @default(true)
  rejectCam          Boolean           @default(true)
  rejectTelesync     Boolean           @default(true)
  rejectScreener     Boolean           @default(true)
  rejectPassworded   Boolean           @default(true)
  rejectSuspicious   Boolean           @default(true)
  preferProper       Boolean           @default(true)
  preferRepack       Boolean           @default(true)
  rules              QualityRule[]
  decisions          ReleaseDecision[]
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
}

model QualityRule {
  id        String         @id @default(cuid())
  profileId String
  profile   QualityProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  kind      String
  value     String
  score     Int            @default(0)
  required  Boolean        @default(false)
  rejected  Boolean        @default(false)
  createdAt DateTime       @default(now())
}

model ReleaseDecision {
  id           String          @id @default(cuid())
  profileId    String?
  profile      QualityProfile? @relation(fields: [profileId], references: [id], onDelete: SetNull)
  releaseTitle String
  releaseGuid  String?
  accepted     Boolean
  score        Int
  reasons      String[]
  parsed       Json
  createdAt    DateTime        @default(now())
}

model SearchHistory {
  id        String   @id @default(cuid())
  type      String
  query     Json
  resultCount Int
  status    String
  message   String?
  createdAt DateTime @default(now())
}

model UsenetServer {
  id            String   @id @default(cuid())
  name          String
  host          String
  port          Int
  ssl           Boolean  @default(true)
  username      String?
  password      String?
  connections   Int      @default(10)
  priority      Int      @default(0)
  enabled       Boolean  @default(true)
  isBackup      Boolean  @default(false)
  retentionDays Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model NzbDocument {
  id          String    @id @default(cuid())
  title       String
  guid        String?   @unique
  path        String
  backupPath  String?
  poster      String?
  groups      String[]
  totalSize   Float     @default(0)
  fileCount   Int       @default(0)
  segmentCount Int      @default(0)
  valid       Boolean   @default(true)
  errors      String[]
  files       NzbFile[]
  mounts      VfsMount[]
  download    Download?
  createdAt   DateTime  @default(now())
}

model NzbFile {
  id            String       @id @default(cuid())
  nzbDocumentId String
  nzbDocument   NzbDocument  @relation(fields: [nzbDocumentId], references: [id], onDelete: Cascade)
  subject       String
  poster        String?
  date          DateTime?
  groups        String[]
  size          Float        @default(0)
  segments      NzbSegment[]
}

model NzbSegment {
  id        String  @id @default(cuid())
  nzbFileId String
  nzbFile   NzbFile @relation(fields: [nzbFileId], references: [id], onDelete: Cascade)
  number    Int
  bytes     Float
  articleId String
}

model VfsMount {
  id            String      @id @default(cuid())
  nzbDocumentId String
  nzbDocument   NzbDocument @relation(fields: [nzbDocumentId], references: [id], onDelete: Cascade)
  name          String
  path          String      @unique
  status        String      @default("mounted")
  streamable    Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Download {
  id            String       @id @default(cuid())
  title         String
  source        String
  status        String       @default("queued")
  priority      Int          @default(0)
  progress      Float        @default(0)
  size          Float        @default(0)
  downloaded    Float        @default(0)
  speedBytesSec Float        @default(0)
  etaSeconds    Int?
  error         String?
  nzbDocumentId String?      @unique
  nzbDocument   NzbDocument? @relation(fields: [nzbDocumentId], references: [id], onDelete: SetNull)
  jobId         String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  completedAt   DateTime?
  repairJobs     RepairJob[]
  imports        ImportItem[]
}

model RequestProvider {
  id                  String         @id @default(cuid())
  type                String
  name                String
  baseUrl             String
  apiKey              String
  enabled             Boolean        @default(true)
  syncIntervalMinutes Int            @default(15)
  defaultMovieProfile String?
  defaultTvProfile    String?
  lastSyncAt          DateTime?
  lastError           String?
  requests            MediaRequest[]
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
}

model MediaRequest {
  id                String           @id @default(cuid())
  providerId        String?
  provider          RequestProvider? @relation(fields: [providerId], references: [id], onDelete: SetNull)
  externalId        String
  mediaType         String
  title             String
  year              Int?
  tmdbId            String?
  tvdbId            String?
  imdbId            String?
  seasons           Json?
  episodes          Json?
  requestedBy       String?
  requestedQuality  String?
  externalStatus    String?
  status            String           @default("pending")
  selectedProfileId String?
  selectedRelease   Json?
  downloadId        String?
  imports           ImportItem[]
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  @@unique([providerId, externalId])
}

model RepairJob {
  id          String   @id @default(cuid())
  downloadId  String
  download    Download @relation(fields: [downloadId], references: [id], onDelete: Cascade)
  type        String
  status      String   @default("queued")
  message     String?
  output      String?
  startedAt   DateTime?
  completedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model FailedRelease {
  id        String   @id @default(cuid())
  guid      String?
  title     String
  reason    String
  downloadId String?
  createdAt DateTime @default(now())
}

model BlocklistItem {
  id          String   @id @default(cuid())
  guid        String?
  title       String
  reason      String
  source      String?
  release     Json?
  expiresAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ImportItem {
  id            String       @id @default(cuid())
  downloadId    String?
  download      Download?    @relation(fields: [downloadId], references: [id], onDelete: SetNull)
  requestId     String?
  request       MediaRequest? @relation(fields: [requestId], references: [id], onDelete: SetNull)
  mediaType     String
  title         String
  year          Int?
  season        Int?
  episode       Int?
  sourcePath    String
  completedPath String
  status        String       @default("imported")
  metadataPath  String?
  stableIdPath  String?
  symlinks      Symlink[]
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Symlink {
  id          String     @id @default(cuid())
  importId    String?
  importItem  ImportItem? @relation(fields: [importId], references: [id], onDelete: SetNull)
  sourcePath  String
  linkPath    String     @unique
  status      String     @default("ok")
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model MediaLibraryItem {
  id                String   @id @default(cuid())
  sourceKey         String   @unique
  mediaType         String
  title             String
  sortTitle         String
  year              Int?
  tmdbId            String?
  tvdbId            String?
  imdbId            String?
  posterUrl         String?
  backdropUrl       String?
  overview          String?
  metadataProvider  String?
  metadataUpdatedAt DateTime?
  season            Int?
  episode           Int?
  episodeTitle      String?
  episodeOverview   String?
  episodeAirDate    DateTime?
  requestedBy       String?
  requestProvider   String?
  requestId         String?
  qualityProfileId  String?
  selectedReleaseId String?
  downloadId        String?
  nzbId             String?
  vfsMountId        String?
  importStrategy    String?
  libraryStatus     String   @default("requested")
  streamStatus      String   @default("unknown")
  healthStatus      String   @default("unknown")
  folderPath        String?
  filePath          String?
  symlinkPath       String?
  strmPath          String?
  quality           String?
  source            String?
  codec             String?
  audio             String?
  hdr               Boolean  @default(false)
  dv                Boolean  @default(false)
  releaseGroup      String?
  size              Float?
  duration          Float?
  lastStreamedAt    DateTime?
  streamCount       Int      @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}
